		<item>
			<title>خليل الحية رئيسا.. حماس عند مفترق الطرق</title>
			<link>https://www.ajnet.me/politics/2026/7/21/%D8%AE%D9%84%D9%8A%D9%84-%D8%A7%D9%84%D8%AD%D9%8A%D8%A9-%D8%B1%D8%A6%D9%8A%D8%B3%D8%A7-%D8%AD%D9%85%D8%A7%D8%B3-%D8%B9%D9%86%D8%AF-%D9%85%D9%81%D8%AA%D8%B1%D9%82-%D8%A7%D9%84%D8%B7%D8%B1%D9%82</link>
