			<link>https://www.ajnet.me/politics/2026/4/26/%D9%85%D9%81%D9%83%D8%B1-%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A-%D8%AA%D8%B1%D9%85%D8%A8-%D9%84%D9%85-%D9%8A%D9%86%D8%AA%D8%B5%D8%B1-%D9%81%D9%8A-%D8%A7%D9%84%D8%AD%D8%B1%D8%A8-%D8%B9%D9%84%D9%89</link>
