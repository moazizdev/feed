			<link>https://www.ajnet.me/news/2026/7/2/%D8%A3%D9%84%D9%81-%D9%8A%D9%88%D9%85-%D9%85%D9%86-%D8%A7%D9%84%D8%A5%D8%A8%D8%A7%D8%AF%D8%A9-%D9%85%D8%A2%D8%B0%D9%86-%D8%BA%D8%B2%D8%A9-%D8%AA%D8%AD%D8%AA-%D8%A7%D9%84%D8%B1%D9%83%D8%A7%D9%85</link>
