		<item>
			<title>إعلان النتائج الأولية للانتخابات المحلية في الضفة ودير البلح</title>
			<link>https://www.ajnet.me/news/2026/4/26/%D8%A5%D8%B9%D9%84%D8%A7%D9%86-%D8%A7%D9%84%D9%86%D8%AA%D8%A7%D8%A6%D8%AC-%D8%A7%D9%84%D8%A3%D9%88%D9%84%D9%8A%D8%A9-%D9%84%D9%84%D8%A7%D9%86%D8%AA%D8%AE%D8%A7%D8%A8%D8%A7%D8%AA-2</link>
						<media:thumbnail url="https://www.ajnet.me/wp-content/uploads/2026/04/image-1777201221.jpg?resize=770%2C513&amp;quality=80" />
