			<guid isPermaLink="false">1779816740523587</guid>
		</item>
		<item>
			<title>بإمكانات بسيطة.. خياط وحلاق وإسكافي يصنعون مظاهر العيد في غزة</title>
			<link>https://www.ajnet.me/politics/2026/5/26/%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D8%A3%D8%B6%D8%AD%D9%89-%D8%BA%D8%B2%D8%A9-%D8%A3%D8%AD%D8%B0%D9%8A%D8%A9-%D8%AD%D9%84%D8%A7%D9%82-%D8%AE%D9%8A%D8%A7%D8%B7</link>
