			<link>https://www.ajnet.me/politics/2026/5/17/%D8%A8%D9%86-%D8%BA%D9%88%D8%B1%D9%8A%D9%88%D9%86-%D9%85%D8%AF%D9%81%D9%88%D9%86-%D9%81%D9%8A-%D9%88%D8%B7%D9%86%D9%8A-%D9%88%D8%A3%D9%86%D8%A7-%D8%A8%D8%A7%D9%84%D9%85%D9%86%D9%81%D9%89</link>
