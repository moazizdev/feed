			<link>https://www.ajnet.me/politics/2026/6/14/%D9%87%D9%84-%D8%AA%D8%B5%D8%AF%D8%B9%D8%AA-%D8%B9%D9%82%D9%8A%D8%AF%D8%A9-%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D8%A7%D9%84%D8%A5%D8%B3%D8%B1%D8%A7%D8%A6%D9%8A%D9%84%D9%8A-%D8%A8%D8%B9%D8%AF-7</link>
