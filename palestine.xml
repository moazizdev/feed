		<item>
			<title>من هي أمه الحقيقية؟ صورة أسير غزي تثير نزاعا بين والدتين</title>
			<link>https://www.ajnet.me/news/2026/7/8/%D9%85%D9%86-%D9%87%D9%8A-%D8%A3%D9%85%D9%87-%D8%A7%D9%84%D8%AD%D9%82%D9%8A%D9%82%D9%8A%D8%A9-%D8%B5%D9%88%D8%B1%D8%A9-%D8%A3%D8%B3%D9%8A%D8%B1-%D8%BA%D8%B2%D9%8A-%D8%AA%D8%AB%D9%8A%D8%B1</link>
