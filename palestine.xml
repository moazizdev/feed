			<link>https://www.ajnet.me/politics/2026/6/26/%D8%BA%D8%B2%D8%A9-%D9%81%D9%84%D8%B3%D8%B7%D9%8A%D9%86-%D8%A7%D8%AD%D8%AA%D9%84%D8%A7%D9%84-%D8%A5%D8%B3%D8%B1%D8%A7%D8%A6%D9%8A%D9%84-%D8%AC%D8%AB%D8%A7%D9%85%D9%8A%D9%86</link>
