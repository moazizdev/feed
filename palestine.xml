		<item>
			<title>مؤتمر ببروكسل يدعو لفتح ممر بحري إلى غزة وتعليق الشراكة مع إسرائيل</title>
			<link>https://www.ajnet.me/news/2026/4/22/%D9%85%D8%A4%D8%AA%D9%85%D8%B1-%D8%A8%D8%A8%D8%B1%D9%88%D9%83%D8%B3%D9%84-%D9%8A%D8%AF%D8%B9%D9%88-%D9%84%D9%81%D8%AA%D8%AD-%D9%85%D9%85%D8%B1-%D8%A8%D8%AD%D8%B1%D9%8A-%D8%A5%D9%84%D9%89</link>
