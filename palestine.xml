		<item>
			<title>تدمير الجذور والتاريخ.. ماذا وراء مسح الاحتلال البيئة العمرانية لأحياء غزة؟</title>
			<link>https://www.ajnet.me/news/2026/6/7/%D8%AA%D8%AF%D9%85%D9%8A%D8%B1-%D8%A7%D9%84%D8%AC%D8%B0%D9%88%D8%B1-%D9%88%D8%A7%D9%84%D8%AA%D8%A7%D8%B1%D9%8A%D8%AE-%D9%85%D8%A7%D8%B0%D8%A7-%D9%88%D8%B1%D8%A7%D8%A1-%D9%85%D8%B3%D8%AD</link>
