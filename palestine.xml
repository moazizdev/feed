			<link>https://www.ajnet.me/politics/2026/6/9/%D9%84%D9%85%D8%A7%D8%B0%D8%A7-%D8%A7%D8%AE%D8%AA%D8%A7%D8%B1-%D9%86%D8%AA%D9%86%D9%8A%D8%A7%D9%87%D9%88-%D8%A8%D9%86-%D8%B9%D8%B2%D8%B1%D8%A7-%D8%B1%D8%A6%D9%8A%D8%B3%D8%A7</link>
