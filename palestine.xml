			<link>https://www.ajnet.me/politics/2026/4/14/%D8%A7%D9%84%D8%AE%D8%B3%D8%A7%D8%B1%D8%A9-%D8%A8%D8%A8%D9%88%D8%AF%D8%A7%D8%A8%D8%B3%D8%AA-%D9%88%D8%A7%D9%84%D9%82%D9%84%D9%82-%D9%81%D9%8A-%D8%AA%D9%84-%D8%A3%D8%A8%D9%8A%D8%A8-%D9%87%D9%84</link>
