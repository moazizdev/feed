		<item>
			<title>قصة رجل الأعمال الذي طلبت منه بريطانيا التجسس على "فلسطين أكشن"</title>
			<link>https://www.ajnet.me/politics/2026/6/21/%D9%82%D8%B5%D8%A9-%D8%B1%D8%AC%D9%84-%D8%A7%D9%84%D8%A3%D8%B9%D9%85%D8%A7%D9%84-%D8%A7%D9%84%D8%B0%D9%8A-%D8%B7%D9%84%D8%A8%D8%AA-%D9%85%D9%86%D9%87-%D8%A8%D8%B1%D9%8A%D8%B7%D8%A7%D9%86%D9%8A%D8%A7</link>
